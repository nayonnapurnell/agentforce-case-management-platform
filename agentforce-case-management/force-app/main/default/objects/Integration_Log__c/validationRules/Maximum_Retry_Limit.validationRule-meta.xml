<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Maximum_Retry_Limit</fullName>
    <active>true</active>
    <description>Prevents runaway aync jobs.</description>
    <errorConditionFormula>Retry_Count__c &gt; 3</errorConditionFormula>
    <errorDisplayField>Retry_Count__c</errorDisplayField>
    <errorMessage>Maximum retry limit exceeded.</errorMessage>
</ValidationRule>
